# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kreativibe"

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_api_key
EMAIL_FROM="Kreativibe <noreply@kreativibe.co.ke>"
FRONTEND_URL=http://localhost:3000

# Firebase Storage
FIREBASE_PROJECT_ID=kreativibe
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@kreativibe.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=kreativibe-assets.appspot.com

# OpenRouter (AI-assisted campaigns)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o
